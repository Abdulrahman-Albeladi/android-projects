<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.TestLayout" parent="Theme.Material3.DayNight.NoActionBar" />

    <style name="Theme.TestLayout" parent="Base.Theme.TestLayout" />

    <style name="MidnightColors">
        <item name="android:background">@color/dark_blue</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="MidnightColors.Header" parent="MidnightColors">
        <item name="android:background">@color/dark_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20sp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <style name="MidnightColors.LocalRuns" parent="MidnightColors.Header">
        <item name="android:background">@color/lighter_blue</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="MidnightColors.Leaderboard" parent="MidnightColors.LocalRuns">
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
